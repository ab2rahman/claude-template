# ═══════════════════════════════════════════════════════════════
# Claude Code - Environment Variables Template
# ═══════════════════════════════════════════════════════════════
#
# Usage:
#   1. Copy this file to .env: cp .env.template .env
#   2. Fill in your actual credentials in .env
#   3. Source in ~/.bashrc or ~/.zshrc: source ~/.claude/.env
#
# IMPORTANT: Never commit .env file to git! It contains secrets.
# This file (.env.template) is safe to commit.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# MCP SERVERS - Model Context Protocol
# ───────────────────────────────────────────────────────────────
# These variables are used by .mcp.json configuration

# File System Paths
# HOME_PATH=/home/username              # Your home directory
# PROJECTS_ROOT=/path/to/projects       # Root projects directory
# GIT_REPO_PATH=/path/to/repo           # Specific git repository

# ───────────────────────────────────────────────────────────────
# AI / LLM API KEYS
# ───────────────────────────────────────────────────────────────
# Anthropic Claude (Required for Claude Code)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# Claude Code Settings (used by settings.json)
# CLAUDE_AUTH_TOKEN=your-claude-auth-token-here
# API_TIMEOUT_MS=3000000

# OpenAI (Optional - for GPT models or MCP server)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Google AI / Gemini (Optional)
# Get from: https://makersuite.google.com/app/apikey
# GOOGLE_AI_API_KEY=your-google-ai-key-here

# Google Cloud Credentials (for GDrive, Gmail, etc.)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Cohere (Optional)
# Get from: https://dashboard.cohere.ai/api-keys
# COHERE_API_KEY=your-cohere-key-here

# Perplexity (Optional)
# Get from: https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=your-perplexity-key-here

# ───────────────────────────────────────────────────────────────
# VERSION CONTROL
# ───────────────────────────────────────────────────────────────
# GitHub
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your-github-token-here
# GITHUB_USERNAME=your-username

# GitLab
# Get from: https://gitlab.com/-/user_settings/personal_access_tokens
# GITLAB_TOKEN=glpat-your-gitlab-token-here

# Bitbucket
# Get from: https://bitbucket.org/account/settings/app-passwords/
# BITBUCKET_TOKEN=your-bitbucket-token-here

# ───────────────────────────────────────────────────────────────
# PROJECT MANAGEMENT (Jira, Linear, Notion)
# ───────────────────────────────────────────────────────────────
# Atlassian Jira / Confluence
# Get from: https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_TOKEN=your-atlassian-token-here
# ATLASSIAN_INSTANCE=your-instance.atlassian.net
# ATLASSIAN_EMAIL=your-email@example.com

# Linear
# Get from: https://linear.app/settings/api
# LINEAR_API_KEY=your-linear-api-key-here

# Notion
# Get from: https://www.notion.so/my-integrations
# NOTION_API_KEY=your-notion-integration-token-here
# NOTION_DATABASE_ID=your-database-id

# ───────────────────────────────────────────────────────────────
# WEB SEARCH & SCRAPING
# ───────────────────────────────────────────────────────────────
# Brave Search API
# Get from: https://api.search.brave.com/app/keys
# BRAVE_API_KEY=your-brave-search-api-key

# Google Search API
# Get from: https://console.cloud.google.com/apis/api/customsearch.googleapis.com
# GOOGLE_SEARCH_API_KEY=your-google-search-api-key
# GOOGLE_SEARCH_CX=your-custom-search-engine-id

# Bing Search API
# Get from: https://portal.azure.com/
# BING_SEARCH_API_KEY=your-bing-search-api-key

# ───────────────────────────────────────────────────────────────
# CLOUD PROVIDERS
# ───────────────────────────────────────────────────────────────
# AWS
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Google Cloud
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ───────────────────────────────────────────────────────────────
# DATABASE CONNECTIONS
# ───────────────────────────────────────────────────────────────
# PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_user
# DB_PASSWORD=your-db-password-here
# DB_SCHEMA=public

# MySQL / MariaDB
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_NAME=your_database
# MYSQL_USER=your_user
# MYSQL_PASSWORD=your-mysql-password-here

# MongoDB
# MONGO_URI=mongodb://localhost:27017/your_database

# Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# SQLite (path only)
# SQLITE_PATH=/path/to/database.db

# ───────────────────────────────────────────────────────────────
# MOBILE DEVELOPMENT (Flutter, React Native)
# ───────────────────────────────────────────────────────────────
# Firebase / Google Services
# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_PROJECT_ID=your-firebase-project-id
# GOOGLE_SERVICES_JSON=/path/to/google-services.json

# Apple Developer
# APPLE_ID=your-apple-id@email.com
# APPLE_TEAM_ID=your-team-id
# APP_SPECIFIC_PASSWORD=your-app-specific-password

# Android
# ANDROID_SDK_ROOT=/path/to/android-sdk
# JAVA_HOME=/path/to/java

# ───────────────────────────────────────────────────────────────
# NOTIFICATION & MESSAGING SERVICES
# ───────────────────────────────────────────────────────────────
# Microsoft Teams
# TEAMS_WEBHOOK=your-teams-webhook-url-here

# Slack
# Get from: https://api.slack.com/apps
# SLACK_WEBHOOK=your-slack-webhook-url-here
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Discord
# DISCORD_WEBHOOK=your-discord-webhook-url-here
# DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id

# ───────────────────────────────────────────────────────────────
# GOOGLE APIs & MAPS
# ───────────────────────────────────────────────────────────────
# Google Maps
# Get from: https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Drive
# GDRIVE_API_KEY=your-google-api-key
# GDRIVE_CREDENTIALS=/path/to/service-account.json

# ───────────────────────────────────────────────────────────────
# SERVER / SSH CONNECTIONS
# ───────────────────────────────────────────────────────────────
# Example VPS / Server credentials
# SERVER_HOST=your-server.com
# SERVER_USER=your-username
# SERVER_PASSWORD=your-server-password-here
# SERVER_PORT=22
# SERVER_KEY_PATH=/path/to/private/key

# ───────────────────────────────────────────────────────────────
# PACKAGE MANAGERS & REGISTRIES
# ───────────────────────────────────────────────────────────────
# npm
# NPM_TOKEN=your-npm-token-here

# PyPI
# PYPI_API_TOKEN=your-pypi-token-here

# Docker Hub
# DOCKER_USERNAME=your-docker-username
# DOCKER_PASSWORD=your-docker-password

# ───────────────────────────────────────────────────────────────
# CI/CD PLATFORMS
# ───────────────────────────────────────────────────────────────
# CircleCI
# CIRCLECI_TOKEN=your-circleci-token-here

# Travis CI
# TRAVIS_CI_TOKEN=your-travis-token-here

# ───────────────────────────────────────────────────────────────
# MONITORING & ANALYTICS
# ───────────────────────────────────────────────────────────────
# Sentry (Error tracking)
# SENTRY_DSN=your-sentry-dsn-here
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# DataDog
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_APP_KEY=your-datadog-app-key

# ───────────────────────────────────────────────────────────────
# CONTENT CREATION
# ───────────────────────────────────────────────────────────────
# YouTube
# YOUTUBE_API_KEY=your-youtube-api-key-here

# Vimeo
# VIMEO_API_KEY=your-vimeo-api-key-here
# VIMEO_ACCESS_TOKEN=your-vimeo-access-token

# ───────────────────────────────────────────────────────────────
# ENTERTAINMENT & LIFESTYLE
# ───────────────────────────────────────────────────────────────
# Spotify
# Get from: https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Weather
# Get from: https://www.openweathermap.org/api
# WEATHER_API_KEY=your-weather-api-key

# ───────────────────────────────────────────────────────────────
# AZURE DEVOPS
# ───────────────────────────────────────────────────────────────
# AZURE_PROJECT=your-azure-project-here
# AZURE_ORG=your-organization.visualstudio.com
# AZURE_DEVOPS_TOKEN=your-azure-devops-token

# ───────────────────────────────────────────────────────────────
# CUSTOM VARIABLES
# ───────────────────────────────────────────────────────────────
# Add any custom environment variables you need below
# CUSTOM_VAR=value
