{
  "mcpServers": {
    // ───────────────────────────────────────────────────────────────
    // FILESYSTEM ACCESS
    // ───────────────────────────────────────────────────────────────
    // Access specific directories - adjust paths to your setup
    "filesystem-home": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${HOME_PATH}"],
      "disabled": false
    },
    "filesystem-projects": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECTS_ROOT}"],
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // VERSION CONTROL
    // ───────────────────────────────────────────────────────────────
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": false
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "${GIT_REPO_PATH}"],
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // DATABASES
    // ───────────────────────────────────────────────────────────────
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"],
      "disabled": true
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "${SQLITE_PATH}"],
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // PROJECT MANAGEMENT
    // ───────────────────────────────────────────────────────────────
    "jira": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-atlassian"],
      "env": {
        "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_TOKEN}"
      },
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // WEB & SEARCH
    // ───────────────────────────────────────────────────────────────
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "disabled": true
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "disabled": false
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // GOOGLE SERVICES
    // ───────────────────────────────────────────────────────────────
    "gdrive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GDRIVE_API_KEY": "${GOOGLE_AI_API_KEY}",
        "GDRIVE_CREDENTIALS": "${GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "disabled": true
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gmail"],
      "env": {
        "GMAIL_CREDENTIALS": "${GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "disabled": true
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      },
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // COMMUNICATION
    // ───────────────────────────────────────────────────────────────
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      },
      "disabled": true
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "-e", "NODE_EXTRA_CA_CERTS=${NODE_EXTRA_CA_CERTS}", "@modelcontextprotocol/server-discord"],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      },
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // PRODUCTIVITY & TOOLS
    // ───────────────────────────────────────────────────────────────
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "disabled": false
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "notion-mcp-server"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}",
        "NOTION_DATABASE_ID": "${NOTION_DATABASE_ID}"
      },
      "disabled": true
    },
    "excel": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-excel"],
      "disabled": false
    },

    // ───────────────────────────────────────────────────────────────
    // CLOUD PLATFORMS
    // ───────────────────────────────────────────────────────────────
    "aws": {
      "command": "npx",
      "args": ["-y", "@mcp-server/aws"],
      "env": {
        "AWS_ACCESS_KEY_ID": "${AWS_ACCESS_KEY_ID}",
        "AWS_SECRET_ACCESS_KEY": "${AWS_SECRET_ACCESS_KEY}",
        "AWS_REGION": "${AWS_REGION}"
      },
      "disabled": true
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@mcp-server/azure"],
      "env": {
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
        "AZURE_TENANT_ID": "${AZURE_TENANT_ID}",
        "AZURE_CLIENT_ID": "${AZURE_CLIENT_ID}",
        "AZURE_CLIENT_SECRET": "${AZURE_CLIENT_SECRET}"
      },
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // DEVELOPMENT TOOLS
    // ───────────────────────────────────────────────────────────────
    "docker": {
      "command": "npx",
      "args": ["-y", "@mcp-server/docker"],
      "disabled": true
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "@mcp-server/kubernetes"],
      "disabled": true
    },

    // ───────────────────────────────────────────────────────────────
    // API & DATA SOURCES
    // ───────────────────────────────────────────────────────────────
    "openai": {
      "command": "npx",
      "args": ["-y", "openai-mcp-server"],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      },
      "disabled": true
    },
    "weather": {
      "command": "npx",
      "args": ["-y", "weather-mcp-server"],
      "env": {
        "WEATHER_API_KEY": "${WEATHER_API_KEY}"
      },
      "disabled": true
    },
    "spotify": {
      "command": "npx",
      "args": ["-y", "spotify-mcp-server"],
      "env": {
        "SPOTIFY_CLIENT_ID": "${SPOTIFY_CLIENT_ID}",
        "SPOTIFY_CLIENT_SECRET": "${SPOTIFY_CLIENT_SECRET}"
      },
      "disabled": true
    }
  }
}
